<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Event Manager – Schedule New Event</title>
    <link rel="stylesheet" href="/main.css" />
  </head>
  <body>
    <!-- include global navigation bar -->
    <%- include('common/header') %>

    <main class="middle">
      <h2>Schedule a New Event</h2>

      <!-- create new event form -->
      <form
        action="/organiser/add"
        method="POST"
        class="form-container add-event"
      >
        <!-- Event date and time -->
        <label for="event_date">Date:</label>
        <input type="date" id="event_date" name="event_date" required />

        <label for="event_time">Time:</label>
        <input type="time" id="event_time" name="event_time" required />

        <!-- title and description -->
        <label for="event_title">Event Title:</label>
        <input type="text" id="event_title" name="event_title" required />

        <label for="event_description">Event Description:</label>
        <textarea
          id="event_description"
          name="event_description"
          rows="3"
          required
        ></textarea>

        <!-- Ticket prices -->
        <label for="ticket_price_1">Ticket Price:</label>
        <input
          type="number"
          id="ticket_price_1"
          name="ticket_price_1"
          step="0.01"
          min="0"
          required
        />

        <label for="ticket_price_2">Concession Ticket Price:</label>
        <input
          type="number"
          id="ticket_price_2"
          name="ticket_price_2"
          step="0.01"
          min="0"
          required
        />

        <!-- Ticket capacities -->
        <label for="capacity_ticket_1">Ticket Capacity:</label>
        <input
          type="number"
          id="capacity_ticket_1"
          name="capacity_ticket_1"
          min="0"
          required
        />

        <label for="capacity_ticket_2">Concession Ticket Capacity:</label>
        <input
          type="number"
          id="capacity_ticket_2"
          name="capacity_ticket_2"
          min="0"
          required
        />

        <!-- Display toggle -->
        <label class="inline">
          <input type="checkbox" name="display_status" value="1" />
          Display publicly
        </label>

        <button type="submit">Add Event</button>
      </form>

      <br />
      <a href="/organiser">← Back to dashboard</a>
    </main>
  </body>
</html>
